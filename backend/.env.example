# ── Django ────────────────────────────────────────────────────────────────────
# Genera una clave segura con: python -c "from django.core.utils.crypto import get_random_string; print(get_random_string(50))"
DJANGO_SECRET_KEY=reemplaza-con-una-clave-secreta-larga
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=tuapp.railway.app

# ── CORS / CSRF ────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://tuapp.vercel.app
CSRF_TRUSTED_ORIGINS=https://tuapp.vercel.app

# ── Base de datos (Supabase) ───────────────────────────────────────────────────
DB_ENGINE=django.db.backends.postgresql
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=
DB_HOST=db.xxxxxxxxxxxx.supabase.co
DB_PORT=5432
CONN_MAX_AGE=60

# ── Cloudinary (almacenamiento de imágenes) ───────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Google OAuth ───────────────────────────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://tuapp.railway.app/api/auth/google/callback/
FRONTEND_URL=https://tuapp.vercel.app

# ── Izipay (pasarela de pagos Perú) ───────────────────────────────────────────
# Dejar vacío si aún no está configurado — el sistema funciona sin esto.
IZIPAY_USERNAME=
IZIPAY_PASSWORD=
IZIPAY_PUBLIC_KEY=
IZIPAY_HMAC_SHA256=
IZIPAY_API_URL=https://api.micuentaweb.pe/api-payment/V4

# ── Correo (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=
DEFAULT_FROM_EMAIL=noreply@tudominio.com
