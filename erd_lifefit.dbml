}

Table challenges_userprogress {
  id uuid [pk]
  created_at timestamp
  updated_at timestamp
  deleted_at timestamp [null]
  user_id uuid
  level int
  total_points int
  current_xp int
  next_level_xp int
}

Table nutrition_food {
  id uuid [pk]
  created_at timestamp
  updated_at timestamp
  deleted_at timestamp [null]
  gym_id uuid [null]
  created_by_id uuid [null]
