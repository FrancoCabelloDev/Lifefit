Table core_globalannouncement {
  id uuid [pk]
  created_at timestamp
  updated_at timestamp
  deleted_at timestamp [null]
  title varchar
  message text
  type varchar
  target_audience varchar
  is_active boolean
  expires_at timestamp [null]
}

Table core_featureflag {
  id uuid [pk]
  created_at timestamp
  updated_at timestamp
  deleted_at timestamp [null]
  name varchar
  code varchar
  description text
  is_active_globally boolean
}

Table core_auditlog {
  id uuid [pk]
  created_at timestamp
  updated_at timestamp
  deleted_at timestamp [null]
  user_id uuid [null]
  action varchar
  target_object_id varchar [null]
  target_object_repr varchar [null]
  details jsonb
  ip_address inet [null]
}

Table accounts_user {
  password varchar
  last_login timestamp [null]
  id uuid [pk]
  created_at timestamp
  updated_at timestamp
  deleted_at timestamp [null]
  email varchar
  first_name varchar
  last_name varchar
  role varchar
  dni varchar [null]
  phone varchar [null]
  is_active boolean
  is_staff boolean
  is_superuser boolean
  date_joined timestamp
  gym_id uuid [null]
  puntos int
  nivel int
  google_id varchar [null]
  google_picture varchar [null]
  is_google_account boolean
  profile_picture varchar [null]
  bio text
  specialty varchar
  years_experience smallint [null]
  max_clients smallint
  height_cm decimal [null]
  weight_kg decimal [null]
  fitness_goal varchar
  goal_notes text
}

Table gyms_gym {
  id uuid [pk]
  created_at timestamp
  updated_at timestamp
  deleted_at timestamp [null]
  name varchar
  slug varchar
  description text
  location varchar
  status varchar
  logo varchar [null]
  ruc varchar
  brand_color varchar
  website varchar
  contact_email varchar
  metrics jsonb
  max_athletes int
  max_coaches int
  max_nutritionists int
}

Table gyms_branch {
  id uuid [pk]
  created_at timestamp
  updated_at timestamp
  deleted_at timestamp [null]
  gym_id uuid
  name varchar
  slug varchar
  address varchar
  city varchar
  state varchar
  country varchar
  zipcode varchar
  status varchar
  phone varchar
  latitude decimal [null]
  longitude decimal [null]
}

Table gyms_gymmembershipplan {
  id uuid [pk]
  created_at timestamp
  updated_at timestamp
  deleted_at timestamp [null]
  gym_id uuid
  name varchar
  description text
  price decimal
  duration_days int
  features jsonb
  is_active boolean
  tier varchar
}

Table gyms_gymfeatureflag {
  id uuid [pk]
  created_at timestamp
  updated_at timestamp
  deleted_at timestamp [null]
  gym_id uuid
  feature_flag_id uuid
  is_active boolean
}

Table gyms_checkin {
  id uuid [pk]
  created_at timestamp
  updated_at timestamp
  deleted_at timestamp [null]
  user_id uuid
  gym_id uuid
  branch_id uuid [null]
  method varchar
  timestamp timestamp
}

Table gyms_nutritionistassignment {
  id uuid [pk]
  created_at timestamp
  updated_at timestamp
  deleted_at timestamp [null]
  nutritionist_id uuid
  athlete_id uuid
  gym_id uuid
  is_active boolean
  assigned_at timestamp
}

Table gyms_notification {
  id uuid [pk]
  created_at timestamp
  updated_at timestamp
  deleted_at timestamp [null]
  recipient_id uuid
  actor_id uuid [null]
  notification_type varchar
  title varchar
  message text
  gym_id uuid [null]
  is_read boolean
  link varchar
}

Table gyms_coachassignment {
  id uuid [pk]
  created_at timestamp
  updated_at timestamp
  deleted_at timestamp [null]
  coach_id uuid
  athlete_id uuid
  gym_id uuid
  is_active boolean
  assigned_at timestamp
}

Table gyms_gymsubscription {
  id uuid [pk]
  created_at timestamp
  updated_at timestamp
  deleted_at timestamp [null]
  athlete_id uuid
  gym_id uuid
  plan_id uuid [null]
  status varchar
  start_date date
  end_date date [null]
  auto_renew boolean
}

Table gyms_gympayment {
  id uuid [pk]
  created_at timestamp
  updated_at timestamp
  deleted_at timestamp [null]
  gym_id uuid
  subscription_id uuid [null]
  athlete_id uuid [null]
  plan_id uuid [null]
  amount decimal
  currency varchar
  status varchar
  paid_at timestamp
  due_date date [null]
  payment_method varchar
  reference varchar
  notes text
}

Table gyms_nutritionistappointment {
  id uuid [pk]
  created_at timestamp
  updated_at timestamp
  deleted_at timestamp [null]
  nutritionist_id uuid
  athlete_id uuid
  gym_id uuid
  scheduled_at timestamp
  duration_minutes int
  appointment_type varchar
  status varchar
  notes text
  clinical_notes text
  reschedule_note text
  cancelled_by varchar
}

Table gyms_nutritionistavailability {
  id uuid [pk]
  created_at timestamp
  updated_at timestamp
  deleted_at timestamp [null]
  nutritionist_id uuid
  gym_id uuid
  day_of_week int
  start_time time
  end_time time
  slot_duration_minutes int
  is_active boolean
}

Table gyms_availabilityoverride {
  id uuid [pk]
  created_at timestamp
  updated_at timestamp
  deleted_at timestamp [null]
  nutritionist_id uuid
  gym_id uuid
  date date
  reason varchar
}

Table gyms_bodymeasurement {
  id uuid [pk]
  created_at timestamp
  updated_at timestamp
  deleted_at timestamp [null]
  nutritionist_id uuid [null]
  athlete_id uuid
  gym_id uuid
  measured_at date
  weight_kg decimal [null]
  height_cm decimal [null]
  body_fat_pct decimal [null]
  muscle_mass_kg decimal [null]
  waist_cm decimal [null]
  hip_cm decimal [null]
  arm_cm decimal [null]
  visceral_fat smallint [null]
  notes text
}

Table gyms_athletegoal {
  id uuid [pk]
  created_at timestamp
  updated_at timestamp
  deleted_at timestamp [null]
  athlete_id uuid
  gym_id uuid
  target_weight_kg decimal [null]
  target_body_fat_pct decimal [null]
  target_date date [null]
  notes text
}

Table gyms_nutritionistmessage {
  id uuid [pk]
  created_at timestamp
  updated_at timestamp
  deleted_at timestamp [null]
  nutritionist_id uuid
  athlete_id uuid
  gym_id uuid
  sender_is_nutritionist boolean
  body text
  is_read boolean
}

Table gyms_coachmessage {
  id uuid [pk]
  created_at timestamp
  updated_at timestamp
  deleted_at timestamp [null]
  coach_id uuid
  athlete_id uuid
  gym_id uuid
  sender_is_coach boolean
  body text
  is_read boolean
}

Table workouts_exercise {
  id uuid [pk]
  created_at timestamp
  updated_at timestamp
  deleted_at timestamp [null]
  gym_id uuid [null]
  name varchar
  category varchar
  equipment varchar
  muscle_group varchar
  description text
  media_url varchar
}

Table workouts_workoutroutine {
  id uuid [pk]
  created_at timestamp
  updated_at timestamp
  deleted_at timestamp [null]
  gym_id uuid [null]
  name varchar
  objective text
  level varchar
  duration_minutes int
  status varchar
  points_reward int
  created_by_id uuid [null]
  is_public boolean
  notes text
}

Table workouts_routineexercise {
  id uuid [pk]
  created_at timestamp
  updated_at timestamp
  deleted_at timestamp [null]
  routine_id uuid
  exercise_id uuid
  order int
  sets int
  reps int
  rest_seconds int
  tempo varchar
  weight_kg decimal [null]
}

Table workouts_workoutsession {
  id uuid [pk]
  created_at timestamp
  updated_at timestamp
  deleted_at timestamp [null]
  user_id uuid
  gym_id uuid [null]
  routine_id uuid [null]
  performed_at timestamp
  duration_minutes int
  perceived_exertion int
  completion_percentage decimal
  notes text
  status varchar
  points_awarded int
}

Table workouts_userroutineassignment {
  id uuid [pk]
  created_at timestamp
  updated_at timestamp
  deleted_at timestamp [null]
  user_id uuid
  routine_id uuid
  assigned_by_id uuid [null]
  start_date date
  end_date date [null]
  status varchar
  compliance_percentage decimal
}

Table workouts_sessionexerciselog {
  id uuid [pk]
  created_at timestamp
  updated_at timestamp
  deleted_at timestamp [null]
  session_id uuid
  routine_exercise_id uuid
  sets_completed int
  completed boolean
}

Table workouts_weeklyroutineplan {
  id uuid [pk]
  created_at timestamp
  updated_at timestamp
  deleted_at timestamp [null]
  athlete_id uuid
  coach_id uuid [null]
  routine_id uuid
  day_of_week int
  suggested_time time [null]
  notes text
}

Table challenges_challenge {
  id uuid [pk]
  created_at timestamp
  updated_at timestamp
  deleted_at timestamp [null]
  gym_id uuid [null]
  name varchar
  description text
  type varchar
  start_date date
  start_time time [null]
  end_date date
  responsible_id uuid [null]
  reward_points int
  goal_value int
  status varchar
  verification_type varchar
  max_participants int [null]
  target_role varchar
}

Table challenges_challengeparticipation {
  id uuid [pk]
  created_at timestamp
  updated_at timestamp
  deleted_at timestamp [null]
  challenge_id uuid
  user_id uuid
  progress int
  status varchar
  points_earned int
  last_update timestamp
  evidence_note text
  verified_by_id uuid [null]
  verified_at timestamp [null]
  rejection_note text
}

Table challenges_badge {
  id uuid [pk]
  created_at timestamp
  updated_at timestamp
  deleted_at timestamp [null]
  gym_id uuid [null]
  name varchar
  description text
  icon varchar
